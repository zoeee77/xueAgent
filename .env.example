# ==========================================
# xueAgent 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ==========================================

# ─── LLM 配置 ──────────────────────────────
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# ─── JWT 认证 ──────────────────────────────
# 生产环境务必更换为强随机密钥
JWT_SECRET_KEY=your-jwt-secret-key-change-in-prod

# ─── Embedding 配置 ────────────────────────
# EMBEDDING_STRATEGY: hash | local | api
EMBEDDING_STRATEGY=hash
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh
EMBEDDING_CACHE_MAX_SIZE=10000

# ─── Vector Index 引擎 ─────────────────────
# faiss | numpy | auto | qdrant
# auto: 自动检测 faiss，未安装则回退 numpy
# qdrant: 使用 Qdrant 云向量数据库
VECTOR_INDEX_ENGINE=auto

# ─── Qdrant 向量数据库配置 ─────────────────
QDRANT_URL=https://your-qdrant-instance.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=majors

# ─── PostgreSQL 数据库配置 ─────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xueAgent
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# ─── 检索权重 ──────────────────────────────
# 三项权重之和应为 1.0
RETRIEVAL_WEIGHT_SEMANTIC=0.40
RETRIEVAL_WEIGHT_RULE=0.35
RETRIEVAL_WEIGHT_KEYWORD=0.25

# ─── 应用配置 ──────────────────────────────
CACHE_TTL_SECONDS=300
MAX_HISTORY_LENGTH=20
BACKEND_URL=http://localhost:8000
